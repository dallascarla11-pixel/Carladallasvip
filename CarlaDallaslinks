/* 🌫️ TON FOND SATIN */
.bg {
  position: fixed;
  width: 120%;
  height: 120%;
  top: -10%;
  left: -10%;
  background-image: url.bg {
position: fixed;
width: 140%;
height: 140%;
top: -20%;
left: -20%;

background:
radial-gradient(circle at 20% 30%, rgba(255,255,255,0.18), transparent 40%),
radial-gradient(circle at 80% 60%, rgba(255,255,255,0.12), transparent 50%),
radial-gradient(circle at 50% 80%, rgba(255,255,255,0.10), transparent 50%),
radial-gradient(circle at 60% 20%, rgba(255,255,255,0.08), transparent 40%),
#000;

filter: blur(120px) contrast(1.3) brightness(0.6);

animation: satinMove 60s ease-in-out infinite alternate;

z-index: -1;
}

@keyframes satinMove {
0% {
transform: scale(1) translate(0%, 0%);
}
50% {
transform: scale(1.05) translate(-3%, 3%);
}
100% {
transform: scale(1.1) translate(3%, -3%);
}
};
  background-size: cover;
  background-position: center;
  filter: brightness(0.45) contrast(1.2);
  animation: move 50s ease-in-out infinite alternate;
  z-index: -1;
}

@keyframes move {
  0% { transform: scale(1) translate(0,0); }
  100% { transform: scale(1.08) translate(2%,-2%); }
}

/* ✨ NOM */
.title {
  font-family: 'Allura', cursive;
  font-size: 54px;
  text-align: center;
  margin-top: 60px;
  color: #f5f5f5;

  text-shadow:
    0 0 15px rgba(255,255,255,0.2),
    0 0 40px rgba(255,255,255,0.08);
}

/* slogan */
.subtitle {
  text-align: center;
  font-size: 12px;
  letter-spacing: 1.5px;
  margin-top: 2px;
  opacity: 0.7;
}

/* 📸 PHOTO */
.profile {
  width: 150px;
  height: 150px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.9);
  object-fit: cover;
  display: block;
  margin: 30px auto;

  box-shadow:
    0 0 25px rgba(255,255,255,0.25),
    0 0 70px rgba(255,255,255,0.1);
}

/* CTA */
.cta {
  text-align: center;
  font-size: 18px;
  letter-spacing: 4px;
  margin-bottom: 30px;
  position: relative;

  text-shadow:
    0 0 15px rgba(255,255,255,0.4),
    0 0 35px rgba(255,255,255,0.15);
}

.cta::after {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 200%;
  height: 100%;
  background: linear-gradient(120deg, transparent, rgba(255,255,255,0.6), transparent);
  animation: shine 3s infinite;
}

@keyframes shine {
  100% { left: 100%; }
}

/* 🔗 BOUTONS */
.btn {
  display: block;
  width: 80%;
  margin: 14px auto;
  padding: 15px;
  text-align: center;
  text-decoration: none;
  color: #f0f0f0;

  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.6);

  background: rgba(255,255,255,0.04);

  box-shadow:
    0 0 15px rgba(255,255,255,0.1),
    inset 0 0 10px rgba(255,255,255,0.05);

  transition: 0.3s;
}

.btn:hover {
  box-shadow:
    0 0 25px rgba(255,255,255,0.35),
    inset 0 0 20px rgba(255,255,255,0.1);
  transform: translateY(-2px);
}

/* MYM */
.btn.main {
  padding: 20px;
  font-size: 18px;
}

.promo {
  display: block;
  font-size: 12px;
  margin-top: 6px;
}

.promo b {
  color: #ff2b2b;
}

